<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StudentBinding.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="30,0" Spacing="25">

            <!--  תמונת פרופיל  -->
            <Image 
                Aspect="AspectFit"
                HeightRequest="185"
                SemanticProperties.Description="Student profile image"
                Source="{Binding DisplayedStudent.ProfilePicture}" />

            <!--  שם התלמיד  -->
            <Label
                FontAttributes="Bold"
                FontSize="32"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                SemanticProperties.HeadingLevel="Level1"
                Text="{Binding DisplayedStudent.FullName}"
                TextColor="MidnightBlue" />

            <!--  גיל  -->
            <Label
                FontSize="24"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                SemanticProperties.Description="Student age"
                SemanticProperties.HeadingLevel="Level2"
                Text="{Binding DisplayedStudent.Age}"
                TextColor="MidnightBlue" />

            <!--  תאריך לידה  -->
            <DatePicker
                Date="{Binding DisplayedStudent.Birthday, Mode=TwoWay}"
                FontSize="24"
                HorizontalOptions="Center"
                SemanticProperties.Description="Student birth date"
                TextColor="MidnightBlue" />

            <!--  כתובת מייל  -->
            <Label
                FontSize="24"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                SemanticProperties.Description="Student email address"
                Text="{Binding DisplayedStudent.EmailAddress}"
                TextColor="MidnightBlue" />

            <!--  טלפון  -->
            <Label
                FontSize="24"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                SemanticProperties.Description="Student phone number"
                Text="{Binding DisplayedStudent.PhoneNumber}"
                TextColor="MidnightBlue" />

            <Button Text="Click here to change student"
                    Clicked="OnChangeStudent"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>